From 64044f8cb9481c2c5e7964340bcde448373f8274 Mon Sep 17 00:00:00 2001
From: Matt Leon <mattleon@google.com>
Date: Thu, 12 Mar 2026 18:09:21 -0400
Subject: [PATCH] Prefix wasmtime API with wasmtime_

This patch is generated from the following commands:

```bash
find ./crates/c-api -type f -exec sed -i                          \
    -e 's/\ wasm_/\ wasmtime_wasm_/g'                             \
    -e 's/\*wasm_/\*wasmtime_wasm_/g'                             \
    -e 's/^wasm_/wasmtime_wasm_/g'                                \
    -e 's/<wasm_/<wasmtime_wasm_/g'                               \
    -e 's/\.wasm_/\.wasmtime_wasm_/g'                             \
    -e 's/\&wasm_/\&wasmtime_wasm_/g'                             \
    -e 's/\[wasm_/\[wasmtime_wasm_/g'                             \
    -e 's/wasmtime_config_wasm_/wasmtime_config_wasmtime_wasm_/g' \
    -e 's/(wasm_/(wasmtime_wasm_/g' {} \;
cat >src/lib.rs <<EOF
pub use wasmtime_c_api;
EOF
```

Signed-off-by: Matt Leon <mattleon@google.com>
