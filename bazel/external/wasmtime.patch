From 6666e18cc9a4aece458da8d38d948e60d4c8b266 Mon Sep 17 00:00:00 2001
From: Matt Leon <mattleon@google.com>
Date: Thu, 12 Mar 2026 15:26:28 -0400
Subject: [PATCH] Create lib.rs that exports wasmtime_c_api

We need to wrap the wasmtime_c_api crate in rust_static_library to be
able to link with the cc_library. Since this create is used as the
wasmtime_c_api in proxy-wasm, we can re-use the src/lib.rs file to
provide this and encapsulate it in the wasmtime.BUILD file.

Signed-off-by: Matt Leon <mattleon@google.com>
---
 src/lib.rs | 10 +---------
 1 file changed, 1 insertion(+), 9 deletions(-)

diff --git a/src/lib.rs b/src/lib.rs
index 296c75d85..e110da813 100644
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -1,10 +1,2 @@
-//! The Wasmtime command line interface (CLI) crate.
-//!
-//! This crate implements the Wasmtime command line tools.
+pub use wasmtime_c_api;
 
-#![deny(missing_docs)]
-
-pub mod commands;
-
-#[cfg(feature = "run")]
-pub(crate) mod common;
